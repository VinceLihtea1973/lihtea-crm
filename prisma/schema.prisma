// Lihtea platform — schéma Prisma v2
// Niveau 1 : CRM opérationnel complet (Comptes / Contacts / Deals / Activités
// / Listes ICP / Séquences Resend / Propositions / Tâches).
// Multi-tenant : chaque table métier porte un tenantId indexé.
// Contraintes principales :
//  - NextAuth garde "Account" pour OAuth. "Compte" en UI = Company en base.
//  - Toutes les entités métier cascadent sur Tenant.
//  - Les relations polymorphes d'Activity sont faites via FK optionnelles
//    (companyId / contactId / dealId) — plus simple et typé que polymorphe.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════
// TENANCY + AUTH
// ═══════════════════════════════════════════════════════════════════

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  companies    Company[]
  contacts     Contact[]
  deals        Deal[]
  activities   Activity[]
  lists        List[]
  sequences    Sequence[]
  proposals    Proposal[]
  tasks        Task[]
  gmailAccount GmailAccount?

  @@map("tenants")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  passwordHash  String?
  role          UserRole  @default(MEMBER)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  accounts Account[]
  sessions Session[]

  // Relations métier "propriétaire"
  ownedDeals        Deal[]     @relation("DealOwner")
  createdActivities Activity[] @relation("ActivityCreatedBy")
  assignedTasks     Task[]     @relation("TaskAssignee")
  ownedLists        List[]     @relation("ListOwner")
  ownedSequences    Sequence[] @relation("SequenceOwner")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ═══════════════════════════════════════════════════════════════════
// CRM — ENTITÉS RÉFÉRENTIELLES
// ═══════════════════════════════════════════════════════════════════

enum CompanyStatus {
  PROSPECT
  LEAD
  CLIENT
  LOST
}

enum CompanySource {
  SEED
  SIRENE
  PAPPERS
  MANUAL
  IMPORT
}

enum CategorieEntreprise {
  TPE
  PME
  ETI
  GE
}

model Company {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Identifiants légaux (INSEE)
  name          String
  siren         String?
  siret         String? // établissement siège
  apeCode       String? // code NAF niveau 5 (ex : "52.10B")
  legalForm     String? // libellé (ex : "SAS", "SARL")
  legalFormCode String? // code INSEE catégorie juridique (ex : "5710")

  // Secteur & taille
  nafBucket           String? // bucket interne (hotel / logistique / retail …)
  headcountBand       String? // tranche INSEE (50-99, 100-199 …)
  revenueM            Float? // CA en M€ (Pappers ou saisie)
  revenueYear         Int? // année de référence
  categorieEntreprise CategorieEntreprise? // TPE/PME/ETI/GE (INSEE)

  // Localisation
  region     String?
  department String? // numéro département (2 chiffres)
  city       String?
  postalCode String?
  address    String?
  latitude   Float?
  longitude  Float?

  // Web
  website     String?
  linkedinUrl String?
  description String? @db.Text

  // Vie de l'entreprise
  creationDate DateTime?
  isActive     Boolean   @default(true)

  // CRM
  status CompanyStatus @default(PROSPECT)
  icp    Int? // score 0-100

  source     CompanySource @default(MANUAL)
  enrichedAt DateTime? // dernière MAJ Sirene/Pappers

  // Relations
  contacts    Contact[]
  deals       Deal[]
  activities  Activity[]
  listMembers ListMember[]
  proposals   Proposal[]
  tasks       Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, siren])
  @@index([tenantId, apeCode])
  @@index([tenantId, region])
  @@map("companies")
}

model Contact {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  firstName String?
  lastName  String
  jobTitle  String?
  email     String?
  phone     String?
  linkedin  String?

  // Flags
  isPrimary   Boolean @default(false) // contact principal du compte
  isExecutive Boolean @default(false) // dirigeant
  optOut      Boolean @default(false) // exclusion prospection

  // Relations
  deals       Deal[]               @relation("DealPrimaryContact")
  activities  Activity[]
  enrollments SequenceEnrollment[]
  tasks       Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, companyId])
  @@index([tenantId, email])
  @@map("contacts")
}

// ═══════════════════════════════════════════════════════════════════
// PIPELINE COMMERCIAL
// ═══════════════════════════════════════════════════════════════════

enum DealStage {
  QUALIFICATION
  DEMO
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

model Deal {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  primaryContactId String?
  primaryContact   Contact? @relation("DealPrimaryContact", fields: [primaryContactId], references: [id], onDelete: SetNull)

  ownerId String?
  owner   User?   @relation("DealOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  name        String
  amount      Decimal   @db.Decimal(12, 2)
  currency    String    @default("EUR")
  probability Int // 0-100
  stage       DealStage @default(QUALIFICATION)

  expectedCloseAt DateTime?
  closedAt        DateTime?
  lostReason      String?

  // Position dans la colonne kanban (ordre manuel dans le stage)
  kanbanOrder Int @default(0)

  activities Activity[]
  proposals  Proposal[]
  tasks      Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, stage])
  @@index([tenantId, ownerId])
  @@index([tenantId, companyId])
  @@map("deals")
}

// ═══════════════════════════════════════════════════════════════════
// JOURNAL D'ACTIVITÉS (polymorphe via FK optionnelles)
// ═══════════════════════════════════════════════════════════════════

enum ActivityType {
  EMAIL_IN // email reçu loggé
  EMAIL_OUT // email envoyé loggé
  CALL // appel passé/reçu
  MEETING // RDV
  NOTE // note manuelle
  TASK_DONE // tâche cochée
  DEAL_MOVED // deal déplacé sur le kanban
  SEQUENCE_SENT // étape de séquence envoyée
  SIGNAL // signal business (levée, dirigeant, CA…)
  ENRICHMENT // enrichissement INSEE/Pappers
}

model Activity {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type    ActivityType
  subject String
  body    String?      @db.Text

  createdById String?
  createdBy   User?   @relation("ActivityCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  // Liens vers les entités concernées (au moins une doit être renseignée)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)

  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([tenantId, occurredAt])
  @@index([tenantId, companyId])
  @@index([tenantId, contactId])
  @@index([tenantId, dealId])
  @@map("activities")
}

// ═══════════════════════════════════════════════════════════════════
// LISTES ICP (recherches sauvegardées)
// ═══════════════════════════════════════════════════════════════════

enum ListType {
  STATIC // liste figée (snapshot)
  DYNAMIC // recherche qui se rafraîchit (refiltrée à chaque ouverture)
}

model List {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String?
  color       String   @default("#14b8a6")
  type        ListType @default(DYNAMIC)

  // Définition de la recherche (JSON sérialisé des filtres)
  filtersJson Json?

  ownerId String?
  owner   User?   @relation("ListOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  members ListMember[]

  lastRefreshedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("lists")
}

model ListMember {
  listId    String
  list      List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  addedAt   DateTime @default(now())

  @@id([listId, companyId])
  @@index([companyId])
  @@map("list_members")
}

// ═══════════════════════════════════════════════════════════════════
// SÉQUENCES (Resend)
// ═══════════════════════════════════════════════════════════════════

enum SequenceStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

model Sequence {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String?
  status      SequenceStatus @default(DRAFT)

  ownerId String?
  owner   User?   @relation("SequenceOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  // Paramètres d'envoi
  fromName  String?
  fromEmail String?
  replyTo   String?

  steps       SequenceStep[]
  enrollments SequenceEnrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@map("sequences")
}

enum SequenceStepType {
  EMAIL // N1 : seul type supporté via Resend
  LINKEDIN // N2+
  CALL // N2+ (rappel tâche)
}

model SequenceStep {
  id         String   @id @default(cuid())
  sequenceId String
  sequence   Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  order     Int
  type      SequenceStepType @default(EMAIL)
  delayDays Int              @default(0) // délai par rapport à l'étape précédente

  subject      String?
  bodyMarkdown String? @db.Text // supporte {{firstName}}, {{companyName}}, etc.

  sends SequenceSend[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sequenceId, order])
  @@map("sequence_steps")
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  REPLIED
  BOUNCED
  UNSUBSCRIBED
  REMOVED
}

model SequenceEnrollment {
  id         String   @id @default(cuid())
  sequenceId String
  sequence   Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  contactId  String
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  currentStepOrder Int              @default(0)
  status           EnrollmentStatus @default(ACTIVE)

  startedAt   DateTime  @default(now())
  nextSendAt  DateTime?
  completedAt DateTime?

  sends SequenceSend[]

  @@unique([sequenceId, contactId])
  @@index([nextSendAt, status])
  @@map("sequence_enrollments")
}

model SequenceSend {
  id           String             @id @default(cuid())
  enrollmentId String
  enrollment   SequenceEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  stepId       String
  step         SequenceStep       @relation(fields: [stepId], references: [id], onDelete: Cascade)

  gmailMessageId String? // id retourné par Gmail API
  gmailThreadId  String? // thread Gmail (pour grouper les réponses)

  sentAt    DateTime?
  openedAt  DateTime?
  clickedAt DateTime?
  bouncedAt DateTime?
  repliedAt DateTime?

  createdAt DateTime @default(now())

  @@index([gmailMessageId])
  @@index([gmailThreadId])
  @@map("sequence_sends")
}

// ═══════════════════════════════════════════════════════════════════
// GMAIL OAUTH (compte d'envoi séquences)
// ═══════════════════════════════════════════════════════════════════

model GmailAccount {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  email        String   // ex : contact@lihtea.com
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime // expiration de l'access token

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("gmail_accounts")
}

// ═══════════════════════════════════════════════════════════════════
// PROPOSITIONS COMMERCIALES
// ═══════════════════════════════════════════════════════════════════

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  SIGNED
  REJECTED
  EXPIRED
}

model Proposal {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  title    String
  amount   Decimal @db.Decimal(12, 2)
  currency String  @default("EUR")

  status ProposalStatus @default(DRAFT)

  // N1 : lien externe (Google Docs / Notion / PDF uploadé)
  // N2 : pdfStorageKey pour génération interne
  externalUrl   String?
  pdfStorageKey String?

  sentAt   DateTime?
  viewedAt DateTime?
  signedAt DateTime?

  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([dealId])
  @@map("proposals")
}

// ═══════════════════════════════════════════════════════════════════
// TÂCHES (todos)
// ═══════════════════════════════════════════════════════════════════

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  DONE
  CANCELLED
}

model Task {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title       String
  description String? @db.Text

  priority TaskPriority @default(NORMAL)
  status   TaskStatus   @default(TODO)

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  // Liens entités concernées (au moins un parmi les 3)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)

  dueAt       DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status, dueAt])
  @@index([tenantId, assigneeId])
  @@map("tasks")
}

# ──────────────────────────────────────────
# Lihtea platform — variables d'environnement
# Copier ce fichier en .env.local pour le dev.
# ──────────────────────────────────────────

# ── Postgres (Supabase) ──
# Dans Supabase > Project Settings > Database > Connection string
#   - DATABASE_URL : pooler (port 6543) avec ?pgbouncer=true&connection_limit=1
#   - DIRECT_URL   : connexion directe (port 5432), utilisée par Prisma migrate
DATABASE_URL="postgresql://postgres.xxxx:YOUR-PASSWORD@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.xxxx:YOUR-PASSWORD@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# ── NextAuth / Auth.js v5 ──
# AUTH_SECRET : générer avec `openssl rand -base64 32`
AUTH_SECRET="change-me-openssl-rand-base64-32"
# AUTH_URL : URL publique de l'app. En dev http://localhost:3000
AUTH_URL="http://localhost:3000"

# ── Google OAuth (optionnel, mais recommandé) ──
# Console Google Cloud > APIs & Services > Credentials > OAuth 2.0
# Authorized redirect URI : http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── INSEE Sirene API (prospection) ──
# Compte gratuit sur https://api.insee.fr — créer une "application" pour obtenir
# le couple client_id / client_secret (OAuth2 client_credentials).
# Si laissés vides, la prospection bascule en mode MOCK (5 résultats fictifs).
INSEE_CLIENT_ID=""
INSEE_CLIENT_SECRET=""
# INSEE_API_BASE : endpoint, ne pas modifier sauf besoin spécifique
INSEE_API_BASE="https://api.insee.fr"

# ── Seed ──
# Credentials créés au premier `pnpm db:seed` pour tester le login par mot de passe.
# Les changer immédiatement en prod.
SEED_ADMIN_EMAIL="vincent@lihtea.com"
SEED_ADMIN_PASSWORD="ChangeMeNow!"
